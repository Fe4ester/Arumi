# Скопируйте файл в deploy.env и заполните адрес сервера.
# deploy.env игнорируется Git и предназначен только для локальных настроек.
DOMAIN=seeonline.ru
SERVER_HOST=203.0.113.10
SERVER_USER=root
SSH_PORT=22
REMOTE_ROOT=/var/www/seeonline.ru

# letsencrypt — рекомендуемый бесплатный сертификат с автообновлением.
# custom — сертификат из .secrets/seeonline.ru.fullchain.pem и приватный ключ.
TLS_MODE=letsencrypt

# Нужен только для Let's Encrypt. Оставьте пустым для регистрации без e-mail.
LETSENCRYPT_EMAIL=
