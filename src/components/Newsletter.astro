---
import { site } from "@/content/site";
---

<section class="newsletter" aria-labelledby="newsletter-title">
  <div data-reveal>
    <p class="eyebrow eyebrow--dark">{site.newsletter.eyebrow}</p>
    <h2 id="newsletter-title">{site.newsletter.title}</h2>
    <p>{site.newsletter.disclaimer}</p>
  </div>

  <!-- Netlify распознаёт форму во время сборки и сохраняет заявки без отдельного сервера. -->
  <form
    class="newsletter__form"
    name="newsletter"
    method="POST"
    action="/thanks"
    data-netlify="true"
    data-netlify-honeypot="company"
    data-reveal
  >
    <input type="hidden" name="form-name" value="newsletter" />
    <p class="honeypot" aria-hidden="true">
      <label>Leave this field empty <input name="company" tabindex="-1" autocomplete="off" /></label>
    </p>
    <label for="newsletter-email">Your email address</label>
    <div class="newsletter__row">
      <input id="newsletter-email" name="email" type="email" placeholder="name@example.com" required autocomplete="email" />
      <button type="submit">Subscribe <span aria-hidden="true">→</span></button>
    </div>
  </form>
</section>
