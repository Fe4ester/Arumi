---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Newsletter from "@/components/Newsletter.astro";
import { works, type Work } from "@/content/site";

/** Astro создаёт по одной статической странице для каждого элемента конфига. */
export function getStaticPaths() {
  return works.map((work) => ({ params: { slug: work.slug }, props: { work } }));
}

type Props = { work: Work };
const { work } = Astro.props;
const currentIndex = works.findIndex((item) => item.slug === work.slug);
const nextWork = works[(currentIndex + 1) % works.length];
---

<BaseLayout title={`${work.title} — Dina Makarova`} description={work.summary} image={work.image}>
  <article class="work-detail">
    <header class="work-detail__hero">
      <img class={`work-detail__image--${work.slug}`} src={work.image} alt="" width="1024" height="1536" />
      <div class="work-detail__veil"></div>
      <div class="work-detail__heading">
        <p class="eyebrow">{work.eyebrow}</p>
        <h1>{work.title}</h1>
        <p>{work.summary}</p>
      </div>
    </header>

    <section class="work-detail__body section">
      <p class="work-detail__index">0{currentIndex + 1} / 0{works.length}</p>
      <div data-reveal>
        {work.description.map((paragraph) => <p>{paragraph}</p>)}
        <p class="work-detail__note">Selected projects and publication details will appear here.</p>
      </div>
    </section>

    <a class="next-work" href={`/work/${nextWork.slug}`}>
      <span>Next chapter</span>
      <strong>{nextWork.title}</strong>
      <span aria-hidden="true">→</span>
    </a>
  </article>
  <Newsletter />
</BaseLayout>
